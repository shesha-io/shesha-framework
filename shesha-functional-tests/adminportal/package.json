{
  "name": "@shesha/adminportal",
  "version": "0.0.1",
  "private": false,
  "postinstall": "next",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "build-shesha": "echo \"Build Shesha\" && cd ../../shesha-reactjs && npm install && npm run build && npm pack && shx mv shesha-io-reactjs-*.tgz ../shesha-functional-tests/adminportal/shesha-local.tgz",
    "preinstall": "npm run build-shesha && npm install shesha-local.tgz --force",
    "export": "next export --webpack",
    "start": "NODE_ENV=production node --max-old-space-size=8192 server.js",
    "build:analyze": "ANALYZE=true npm run build",
    "lint": "eslint src/**/*.ts{,x}",
    "lint-errors": "eslint src/**/*.ts{,x} --quiet"
  },
  "overrides": {
    "eslint": "$eslint",
    "next-navigation-guard": {
      "next": "$next"
    },
    "@react-awesome-query-builder/antd": {
      "antd": "$antd",
      "@ant-design/icons": "$@ant-design/icons"
    }
  },
  "resolutions": {
    "rc-treee": "5.8.2"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@bprogress/next": "^3.2.12",
    "@microsoft/applicationinsights-react-js": "^3.1.2",
    "@microsoft/applicationinsights-web": "^2.6.2",
    "@microsoft/signalr": "^8.0.7",
    "@next/bundle-analyzer": "^14.2.4",
    "@shesha-io/reactjs": "file:shesha-local.tgz",
    "@types/react-dom": "^18.2.4",
    "antd": "^6.3.5",
    "antd-style": "^3.7.1",
    "axios": "^1.14.0",
    "camelcase": "^6.2.0",
    "config": "^3.3.6",
    "eslint-config-next": "^16.2.2",
    "file-saver": "^2.0.5",
    "history": "^5.3.0",
    "htmlescape": "^1.1.1",
    "moment": "^2.30.1",
    "nanoid": "^3.1.23",
    "next": "^16.2.2",
    "next-navigation-guard": "^0.2.0",
    "prettier": "^2.2.1",
    "qs": "^6.14.0",
    "rc-picker": "4.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^3.1.4",
    "react-sortablejs": "^6.1.4",
    "react-use": "^17.6.0",
    "sortablejs": "^1.15.6",
    "styled-components": "^5.2.1",
    "swr": "^2.4.1",
    "url-loader": "^4.1.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.3",
    "@testing-library/react": "^11.2.3",
    "@types/node": "20.11.5",
    "@types/react": "^18.2.6",
    "@types/redux-actions": "^2.3.1",
    "@types/styled-components": "^5.1.9",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "dotenv": "^8.2.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsdoc": "^62.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.0.10",
    "isomorphic-unfetch": "^3.1.0",
    "lint-staged": "^15.2.7",
    "nock": "^13.0.6",
    "redux-actions": "^2.6.5",
    "shx": "^0.3.4",
    "typescript": "^5.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npm run lint -- --quiet --fix"
    ]
  }
}
