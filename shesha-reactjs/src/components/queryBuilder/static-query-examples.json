{
  "version": 1,
  "howToUse": "Copy only the logic object from an example and paste it into the Query Builder JSON editor.",
  "assumedFields": [
    "id",
    "city",
    "country",
    "area",
    "population",
    "funFact"
  ],
  "examples": [
    {
      "id": "eq-country-japan",
      "name": "Country equals Japan",
      "logic": {
        "==": [
          {
            "var": "country"
          },
          "Japan"
        ]
      }
    },
    {
      "id": "ne-city-tokyo",
      "name": "City not equal Tokyo",
      "logic": {
        "!=": [
          {
            "var": "city"
          },
          "Tokyo"
        ]
      }
    },
    {
      "id": "contains-literal-country",
      "name": "Country contains letter a (contains/value)",
      "logic": {
        "in": [
          "a",
          {
            "var": "country"
          }
        ]
      }
    },
    {
      "id": "contains-literal-city",
      "name": "City contains letter b (contains/value)",
      "logic": {
        "in": [
          "b",
          {
            "var": "city"
          }
        ]
      }
    },
    {
      "id": "contains-field-source",
      "name": "funFact contains city value (contains/field)",
      "logic": {
        "in": [
          {
            "var": "city"
          },
          {
            "var": "funFact"
          }
        ]
      }
    },
    {
      "id": "contains-evaluate-source",
      "name": "Country contains evaluate result (contains/function)",
      "logic": {
        "in": [
          {
            "evaluate": [
              {
                "expression": "{{\"a\"}}",
                "required": true,
                "type": "mustache"
              }
            ]
          },
          {
            "var": "country"
          }
        ]
      }
    },
    {
      "id": "or-two-contains",
      "name": "Country contains a OR city contains b",
      "logic": {
        "or": [
          {
            "in": [
              "a",
              {
                "var": "country"
              }
            ]
          },
          {
            "in": [
              "b",
              {
                "var": "city"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "between-area",
      "name": "Area between 500 and 2000",
      "logic": {
        "and": [
          {
            ">=": [
              {
                "var": "area"
              },
              500
            ]
          },
          {
            "<=": [
              {
                "var": "area"
              },
              2000
            ]
          }
        ]
      }
    },
    {
      "id": "high-population-and-coastal",
      "name": "Population above 10 and funFact contains coastal",
      "logic": {
        "and": [
          {
            ">": [
              {
                "var": "population"
              },
              10
            ]
          },
          {
            "in": [
              "coastal",
              {
                "var": "funFact"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "nested-country-or-criteria",
      "name": "Country is Japan OR (not Tokyo and population > 8)",
      "logic": {
        "or": [
          {
            "==": [
              {
                "var": "country"
              },
              "Japan"
            ]
          },
          {
            "and": [
              {
                "!=": [
                  {
                    "var": "city"
                  },
                  "Tokyo"
                ]
              },
              {
                ">": [
                  {
                    "var": "population"
                  },
                  8
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": "equals-with-evaluate",
      "name": "City equals evaluate result (function source)",
      "logic": {
        "==": [
          {
            "var": "city"
          },
          {
            "evaluate": [
              {
                "expression": "{{\"Tokyo\"}}",
                "required": true,
                "type": "mustache"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "ignore-unassigned-evaluate",
      "name": "Country contains evaluate result, ignore if unassigned",
      "logic": {
        "in": [
          {
            "evaluate": [
              {
                "expression": "{{data?.regionCode}}",
                "required": false,
                "type": "mustache"
              }
            ]
          },
          {
            "var": "country"
          }
        ]
      }
    }
  ]
}
